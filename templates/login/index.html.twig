{# templates/login/index.html.twig #}
{% extends 'base.html.twig' %}

{# ... #}

{% block body %}
    {% if error %}
        <div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}
    
    <div style="text-align: left; padding-top:15px; font-weight: 600;">
        <form action="{{ path('login') }}" method="post">
            <div class="form-group">
                    <label for="username">Username (Email):</label>
                    <input type="text" id="username" name="_username" value="{{ last_username }}" placeholder="Your email" class="form-control" autocomplete="off" />
            </div>
                    
            <div class="form-group">
                    <label for="password">Password:</label>
                    <input type="password" id="password" name="_password" placeholder="Your password" class="form-control" autocomplete="off" />
            </div>                

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <button type="submit" class="btn btn-block btn-primary margin-top-20">login</button>
        </form>
    </div>

{% endblock %}